# ── Crypto-Knowledge — server-side provider keys ──────────────────────────────
# These belong to the OPERATOR of the tool. They are NEVER returned to callers.
# Every key is optional: without it the relevant module degrades to public RPCs
# (provider mode "open" — limited data, lower rate limits).

# Solana DAS + RPC (https://helius.dev — free tier available)
HELIUS_API_KEY=

# EVM token/NFT inventory (https://alchemy.com — free tier available)
ALCHEMY_API_KEY=

# Unified multichain Etherscan V2 key (one key for ETH/Base/Arbitrum/Polygon/…)
ETHERSCAN_API_KEY=

# Token security / anti-rug (https://gopluslabs.io — free tier available)
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=

# Cross-chain routing aggregator (https://li.fi — key optional, raises limits)
LIFI_API_KEY=

# ── Access control (only relevant when hosted as a public/remote service) ──────
# Local stdio usage leaves this OFF (single trusted caller = the host agent).
ACCESS_GATING_ENABLED=false
# ERC-721 collection that grants free "holder" access (Normies), + the chain it lives on.
HOLDER_NFT_CONTRACT=
HOLDER_NFT_CHAIN=ethereum
# Treasury that receives x402 per-request payments ($0.10) from non-holders.
TREASURY_ADDRESS=
